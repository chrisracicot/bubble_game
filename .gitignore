# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]serSettings/

# MemoryCaptures can get excessively large
/[Mm]emoryCaptures/

# Recordings can get excessively large
/[Rr]ecordings/

# Exported Visual Studio Solution
/*.sln
/*.csproj
/*.unityproj
/*.suo
/*.tmp
/*.user
/*.userprefs
/*.pidb
/*.booproj
/*.svd
/*.pdb
/*.opendb
/*.IDB
/*.BCIE
/*.ethereal
/*.lhdata
/*.db
/*.opendb
/*.ncb

# Unity3D generated meta files
/*.pidb.meta
/*.pdb.meta
/*.mdb.meta

# Unity3D Generated File On Crash Reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Assets
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/[Ll]ink.xml

# OS generated
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
